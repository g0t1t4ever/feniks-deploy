RewriteEngine On

# Redirect non-www → www
RewriteCond %{HTTP_HOST} ^phoenyx\.com\.ua$ [NC]
RewriteRule ^(.*)$ https://www.phoenyx.com.ua/$1 [L,R=301]

# Route /api/contact → api/contact.php
RewriteRule ^api/contact/?$ api/contact.php [L]

# Deny direct access to PHP files outside api/
RewriteRule ^(?!api/).*\.php$ - [F,L]
